# ============================================================
# cybmas — Environment Variables
# Copy this file to .env.local for local development
# ============================================================

# ------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@127.0.0.1:5432/cybmas

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# ------------------------------------------------------------
# Google Authentication
# Used for both Gemini LLM and Vertex AI embeddings
# Local dev: path to service account JSON key file
# Production (GCP): not needed — Cloud Run uses attached service account
# ------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=C:\keys\cybmasacn.json
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# ------------------------------------------------------------
# LLM — Gemini via Vertex AI
# Same model local and production — auth method differs only
# ------------------------------------------------------------
GEMINI_MODEL=gemini-1.5-flash

# ------------------------------------------------------------
# Embeddings — Vertex AI text-embedding-004
# 768-dim everywhere — local and production identical
# ------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ------------------------------------------------------------
# JIRA
# ------------------------------------------------------------
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USER_EMAIL=your-email@yourorg.com

# JIRA project keys mapped to business units
BU_B1_PROJECTS=PROJECT_A,PROJECT_B
BU_B2_PROJECTS=PROJECT_C,PROJECT_D

# JIRA Webhook Secret — set this in JIRA webhook config to validate payloads
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JIRA_WEBHOOK_SECRET=replace-with-random-secret

# Issue types treated as incidents
INCIDENT_ISSUE_TYPES=Incident,Production Issue
INCIDENT_LABELS=incident,production-incident,outage

# ------------------------------------------------------------
# Agent Service Endpoints (local dev)
# ------------------------------------------------------------
ORCHESTRATOR_ENDPOINT=http://localhost:8001
L1L2_AGENT_ENDPOINT=http://localhost:8002
L3_AGENT_ENDPOINT=http://localhost:8003
SESSION_AGENT_ENDPOINT=http://localhost:8004
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
# JWT Authentication
# Generate secret: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
JWT_SECRET_KEY=replace-with-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# ------------------------------------------------------------
# Pipeline
# ------------------------------------------------------------
SYNC_MODE=delta
PUBSUB_TOPIC=jira-events
PUBSUB_SUBSCRIPTION=embedding-worker-sub
GCS_BUCKET=cybmas-raw

# Webhook Receiver (Cloud Run service — receives JIRA webhooks → Pub/Sub)
WEBHOOK_RECEIVER_PORT=8080
# Configure JIRA to POST to: http://localhost:8080/webhook/jira

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_FORMAT=dev
LOG_LEVEL=INFO
